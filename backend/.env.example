# Drone Simulation Backend Configuration

# Server settings
HOST=0.0.0.0
PORT=8000
DEBUG=True

# CORS origins (comma-separated or JSON array)
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# Physics constants (optional - defaults provided)
# AIR_DENSITY=1.225
# GRAVITY=9.81

# Simulation settings
# SIMULATION_TIMESTEP=0.02
# MAX_SIMULATION_TIME=60.0

# Socket.IO settings
# SOCKETIO_PING_TIMEOUT=60
# SOCKETIO_PING_INTERVAL=25

# Component database path (optional)
# COMPONENT_DB_PATH=./data/components.json
